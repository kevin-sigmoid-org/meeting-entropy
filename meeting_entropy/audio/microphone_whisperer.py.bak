"""Vosk-based transcription for audio chunks. No more hallucinations."""
from __future__ import annotations
import json
from pathlib import Path
import numpy as np
from vosk import Model, KaldiRecognizer, SetLogLevel
from meeting_entropy.audio.the_uncomfortable_listener import AudioChunk

# Shut Vosk up
SetLogLevel(-1)


# Map Whisper-style model names to Vosk model directories
_MODEL_MAP = {
    "tiny": {
        "en": "vosk-model-small-en-us-0.15",
        "fr": "vosk-model-small-fr-0.22",
        None: "vosk-model-small-en-us-0.15",
    },
    "small": {
        "en": "vosk-model-small-en-us-0.15",
        "fr": "vosk-model-small-fr-0.22",
        None: "vosk-model-small-en-us-0.15",
    },
    "medium": {
        "en": "vosk-model-en-us-0.22",
        "fr": "vosk-model-fr-0.6-linto-2.2.0",
        None: "vosk-model-en-us-0.22",
    },
    "large": {
        "en": "vosk-model-en-us-0.22",
        "fr": "vosk-model-fr-0.6-linto-2.2.0",
        None: "vosk-model-en-us-0.22",
    },
}


class MicrophoneWhisperer:
    """Transcribes audio chunks using Vosk. Fast, offline, zero hallucinations."""

    def _detect_optimal_tier() -> str:
        """Detects machine specs and returns the recommended model tier."""
        cpu_count = psutil.cpu_count(logical=False) or 1
        ram_gb = psutil.virtual_memory().total / (1024 ** 3)

        if cpu_count >= 8 and ram_gb >= 16:
            return "large"
        elif cpu_count >= 4 and ram_gb >= 8:
            return "small"
        else:
            return "tiny"
            
    def __init__(
        self,
        model_name: str = "small",
        language: str | None = None,
    ) -> None:
        self.model_name = model_name
        self.language = language
        self._model_dir = Path.home() / ".meeting-entropy" / "models"
        self._model_dir.mkdir(parents=True, exist_ok=True)

        # Auto-detect optimal tier if requested
        if model_name == "auto":
            model_name = _detect_optimal_tier()
            print(f"[meeting-entropy] Auto-detected tier: {model_name}")

        # Fallback to small if requested size doesn't exist
        tier = _MODEL_MAP.get(model_name, _MODEL_MAP["small"])
        model_folder = tier.get(language, tier[None])

        model_path = self._model_dir / model_folder

        if not model_path.exists():
            raise FileNotFoundError(
                f"Vosk model not found at {model_path}. "
                f"Download it from https://alphacephei.com/vosk/models "
                f"and unzip it into {self._model_dir}"
            )

        self._model = Model(str(model_path))
        # Vosk expects 16kHz audio
        self._recognizer = KaldiRecognizer(self._model, 16000)

    def transcribe_the_meaningless_words(self, audio: AudioChunk) -> str:
        """Pass audio chunk to Vosk. Returns what it actually heard, not what it dreamed."""
        audio_data = audio.data

        # Ensure mono 1-D
        if audio_data.ndim > 1:
            audio_data = audio_data.mean(axis=1)

        # Vosk wants int16 PCM bytes, not float32
        # AudioChunk.data is float32 normalized [-1.0, 1.0], convert back
        int16_data = (audio_data * 32768.0).astype(np.int16).tobytes()

        if self._recognizer.AcceptWaveform(int16_data):
            result = json.loads(self._recognizer.Result())
            return result.get("text", "")
        else:
            # Partial result (still accumulating)
            partial = json.loads(self._recognizer.PartialResult())
            return partial.get("partial", "")